# Local API keys. Keep this file committed; put real values in .env or .env.local.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOECO_API_KEY=

# Optional one-shot prompt used by scripts/run.sh instead of interactive mode.
PIMOE_PROMPT=

# Local PostgreSQL used by docker-compose.yml and configs/app.example.yaml.
PIMOE_POSTGRES_HOST=localhost
PIMOE_POSTGRES_PASSWORD=pimoe
